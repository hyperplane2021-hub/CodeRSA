# Hugging Face access token, required for gated models such as Llama.
HF_TOKEN=

# Root directory for datasets, caches, and run outputs.
WORKSPACE=/workspace

# Main model and run configuration.
GORSA_MODEL_ID=meta-llama/Meta-Llama-3-8B-Instruct
GORSA_SEED=42
GORSA_LIMIT=378
GORSA_ROOT_DIR=/workspace/runs/codersa_mbpp_seed42

# Runtime knobs.
GORSA_CANDIDATE_OVERSAMPLE=20
GORSA_EVAL_TIMEOUT_SECONDS=2
GORSA_EVAL_WORKERS=4
GORSA_SCORE_BATCH_SIZE=8
GORSA_GENERATION_BATCH_SIZE=8

# vLLM knobs.
VLLM_TASK_BATCH_SIZE=8
VLLM_L0_PROMPT_BATCH_SIZE=16
VLLM_GPU_MEMORY_UTILIZATION=0.65
VLLM_ENFORCE_EAGER=1
