# Hugging Face access token, required for gated models such as Llama.
HF_TOKEN=

# Root directory for datasets, caches, and run outputs.
WORKSPACE=/workspace

# Model and run configuration.
GORSA_MODEL_ID=meta-llama/Meta-Llama-3-8B-Instruct
GORSA_SEED=42
GORSA_LIMIT=378
GORSA_ROOT_DIR=/workspace/runs/codersa_mbpp_seed42

# Required only for BigCodeBench runs.
BIGCODEBENCH_REPO=/workspace/src/bigcodebench
BCB_EVAL_PYTHON=/workspace/.venvs/bcb_eval_py310/bin/python
